# Environment Configuration
# Copy this file to .env and fill in your values

# LLM API Key (required)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Uncomment to use alternative LLM providers:
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM Model (default: gemini-2.5-flash)
# Example: openrouter/nvidia/nemotron-3-ultra-550b-a55b:free
LLM_MODEL=

# Optional base URL for API endpoints (leave empty to use provider default)
# Example: https://api.example.com
OPTIONAL_BASE_URL=

# Data directory (relative to project root)
DATA_DIR=data

# Output directory (relative to project root)
OUTPUT_DIR=output